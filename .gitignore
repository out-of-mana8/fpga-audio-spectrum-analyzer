# ==============================================================================
# Quartus Prime .gitignore — minimal, keep everything useful
# ==============================================================================

# Internal build databases (huge, fully regenerated every compile)
db/
incremental_db/
greybox_tmp/

# Editor/lock files (transient, cause merge conflicts)
*.qws
*.flock
*.bak

# OS junk
.DS_Store
Thumbs.db
desktop.ini
